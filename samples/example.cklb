          "group_title": "SRG-OS-000480-GPOS-00227",
          "rule_title": "RHEL 9 must be a vendor-supported release.",
          "fix_text": "Upgrade to a supported version of RHEL 9.",
          "false_positives": "",
          "false_negatives": "",
          "discussion": "An operating system release is considered supported if the vendor continues to provide security patches for the product.",
          "check_content": "Verify that the version of RHEL 9 is vendor supported with the following command:\n\n$ cat /etc/redhat-release\n\nRed Hat Enterprise Linux release 9.x\n\nIf the installed version of RHEL 9 is not supported, this is a finding.",
          "documentable": "false",
          "mitigations": "",
          "potential_impacts": "",
          "third_party_tools": "",
          "mitigation_control": "",
          "responsibility": "",
          "security_override_guidance": "",
