          "rule_version": "RHEL-09-211010",
          "group_title": "SRG-OS-000480-GPOS-00227",
          "rule_title": "RHEL 9 must implement the Endpoint Security for Linux Threat Prevention tool.",
          "fix_text": "Install and enable the latest McAfee ENSLTP package.",
          "false_positives": "",
          "false_negatives": "",
          "discussion": "Without the use of automated mechanisms to scan for security flaws on a continuous or periodic basis, the operating system or other nonfederal information systems may remain vulnerable.",
          "check_content": "Verify that RHEL 9 has implemented the Endpoint Security for Linux Threat Prevention tool.\n\nCheck that the following package has been installed:\n\n$ sudo rpm -qa | grep -i mcafeetp\n\nIf the McAfee TP package is not installed, this is a finding.",
          "documentable": "false",
          "mitigations": "",
          "potential_impacts": "",
          "third_party_tools": "",
          "mitigation_control": "",
          "responsibility": "",
          "security_override_guidance": "",
          "ia_controls": "",
