        {
          "uuid": "r0000004-0000-0000-0000-000000000004",
          "stig_uuid": "s1s1s1s1-0000-0000-0000-000000000001",
          "target_key": "4081",
          "stig_ref": "DPMS Target RHEL 9",
          "group_id": "V-257780",
          "rule_id": "SV-257780r1_rule",
          "rule_id_src": "SV-257780r1_rule",
          "weight": "10.0",
          "classification": "Unclassified",
          "severity": "medium",
          "rule_version": "RHEL-09-211025",
          "group_title": "SRG-OS-000023-GPOS-00006",
          "rule_title": "RHEL 9 must implement DOD-approved encryption in the OpenSSL package.",
          "fix_text": "Configure OpenSSL to use only DOD-approved TLS encryption by modifying /etc/crypto-policies.",
          "false_positives": "",
          "false_negatives": "",
          "discussion": "Without cryptographic integrity protections, information can be altered by unauthorized users without detection.",
          "check_content": "Verify RHEL 9 OpenSSL library is configured to use TLS 1.2 or greater:\n\n$ openssl version\n\nOpenSSL 3.0.x\n\n$ update-crypto-policies --show\n\nFIPS\n\nIf OpenSSL is not version 3.0 or later, this is a finding.",
          "documentable": "false",
          "mitigations": "",
          "potential_impacts": "",
          "third_party_tools": "",
          "mitigation_control": "",
          "responsibility": "",
          "security_override_guidance": "",
          "ia_controls": "",
          "check_content_ref": { "href": "U_RHEL_9_STIG_V1R2_Manual-xccdf.xml", "name": "M" },
          "legacy_ids": [],
          "ccis": ["CCI-000048", "CCI-002421"],
          "group_tree": [{ "id": "V-257780", "title": "SRG-OS-000023-GPOS-00006", "description": "" }],
          "createdAt": "2025-01-01T00:00:00.000Z",
          "updatedAt": "2025-01-01T00:00:00.000Z",
          "STIGUuid": "s1s1s1s1-0000-0000-0000-000000000001",
          "status": "not_applicable",
          "overrides": {},
          "comments": "System uses hardware encryption module instead.",
          "finding_details": "N/A — System uses a dedicated HSM for cryptographic operations. OpenSSL not used for TLS.",
          "srg_id": "SRG-OS-000023-GPOS-00006"
        },
