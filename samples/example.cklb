          "rule_id": "SV-257781r1_rule",
          "rule_id_src": "SV-257781r1_rule",
          "weight": "10.0",
          "classification": "Unclassified",
          "severity": "low",
          "rule_version": "RHEL-09-211030",
          "group_title": "SRG-OS-000024-GPOS-00007",
          "rule_title": "RHEL 9 must display the date and time of the last successful account logon upon logon.",
          "fix_text": "Configure PAM to display last logon information. Add 'session required pam_lastlog.so showfailed' to /etc/pam.d/postlogin.",
          "false_positives": "",
          "false_negatives": "",
          "discussion": "Providing users with feedback on the last successful logon facilitates user recognition and reporting of unauthorized account use.",
          "check_content": "Verify RHEL 9 displays the date and time of the last successful logon:\n\n$ grep pam_lastlog /etc/pam.d/postlogin\n\nsession required pam_lastlog.so showfailed\n\nIf pam_lastlog is not configured, this is a finding.",
          "documentable": "false",
          "mitigations": "",
          "potential_impacts": "",
          "third_party_tools": "",
          "mitigation_control": "",
          "responsibility": "",
          "security_override_guidance": "",
          "ia_controls": "",
