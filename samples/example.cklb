          "rule_version": "RHEL-09-211020",
          "group_title": "SRG-OS-000023-GPOS-00006",
          "rule_title": "RHEL 9 must display the Standard Mandatory DOD Notice and Consent Banner before granting local or remote access to the system.",
          "fix_text": "Configure RHEL 9 to display the Standard Mandatory DOD Notice by editing /etc/issue.",
          "false_positives": "",
          "false_negatives": "",
          "discussion": "Display of a standardized and approved use notification before granting access ensures privacy and security notification verbiage is consistent.",
          "check_content": "Verify RHEL 9 displays the Standard Mandatory DOD Notice and Consent Banner before granting access.\n\nCheck that the banner is displayed at login with the following command:\n\n$ cat /etc/issue\n\nIf the banner text does not match the Standard Mandatory DOD Notice, this is a finding.",
          "documentable": "false",
          "mitigations": "",
          "potential_impacts": "",
          "third_party_tools": "",
          "mitigation_control": "",
          "responsibility": "",
          "security_override_guidance": "",
          "ia_controls": "",
          "check_content_ref": { "href": "U_RHEL_9_STIG_V1R2_Manual-xccdf.xml", "name": "M" },
